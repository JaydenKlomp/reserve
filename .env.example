# E-mail via TransIP SMTP (de bestaande info@-mailbox) — zet deze ook in Vercel.
# Zonder SMTP_PASS blijft het formulier werken; aanvragen zijn dan alleen zichtbaar in de logs.
SMTP_PASS=

# Optioneel (dit zijn de standaardwaarden):
SMTP_USER=info@reservepadel.nl
SMTP_HOST=smtp.transip.email
SMTP_PORT=465

# Ontvanger van aanvragen (default: info@reservepadel.nl)
CONTACT_TO=info@reservepadel.nl
