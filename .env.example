# Resend (e-mailservice voor het contactformulier) — zet deze ook in Vercel
# Zonder key blijft het formulier werken; aanvragen zijn dan alleen zichtbaar in de logs.
RESEND_API_KEY=

# Ontvanger van aanvragen (default: info@reservepadel.nl)
CONTACT_TO=info@reservepadel.nl

# Afzender. Moet een bij Resend geverifieerd domein zijn.
# Zolang reservepadel.nl nog niet geverifieerd is: laat leeg, dan wordt
# "ReServe <onboarding@resend.dev>" gebruikt.
CONTACT_FROM=
